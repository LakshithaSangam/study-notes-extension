{
  "manifest_version": 3,
  "name": "Study Notes & Bookmarks",
  "version": "0.1.0",
  "description": "Bookmark timestamps and jot sticky notes while watching YouTube or any course video — find them again the instant you're back.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "downloads", "tabs", "unlimitedStorage"],
  "host_permissions": ["<all_urls>"],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/watch*"],
      "js": ["lib/storage.js", "lib/exporter.js", "lib/highlighter.js", "content/youtube.js", "content/core.js"],
      "css": ["content/styles.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "exclude_matches": ["*://*.youtube.com/*"],
      "js": ["lib/storage.js", "lib/exporter.js", "lib/highlighter.js", "content/generic.js", "content/core.js"],
      "css": ["content/styles.css"],
      "run_at": "document_idle"
    }
  ]
}
